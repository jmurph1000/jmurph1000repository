  "type": "module",
  "dependencies": {
    "@prisma/client": "^6.17.0",
    "bcryptjs": "^3.0.2",
    "connect-sqlite3": "^0.9.16",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "nodemailer": "^7.0.9",
    "zod": "^4.1.12"
  },
  "devDependencies": {
