{
  "name": "workspace",
  "version": "1.0.0",
  "description": "A simple FastAPI-based dashboard to track daily cash balances (corporate and customer) and security positions. Upload daily spreadsheets (CSV/XLSX) to store historical balances for trend and reporting. The UI highlights negative trends and potential overdrafts.",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma": "prisma",
    "seed": "ts-node-dev prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmurph1000/jmurph1000repository.git"
  },
