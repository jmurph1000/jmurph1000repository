    "@types/nodemailer": "^7.0.2",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "prisma": "^6.17.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
