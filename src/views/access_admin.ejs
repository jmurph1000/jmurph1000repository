<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Access Governance</title>
    <style>
      body { background: #e6ffe6; color: #0a2a66; font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; }
      .container { max-width: 1100px; margin: 4vh auto; }
      table { width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 18px rgba(0,0,0,0.06); }
      th, td { padding: 12px 14px; border-bottom: 1px solid #eef2ee; text-align: left; vertical-align: top; }
      th { background: #dff6df; color: #0a2a66; }
      form.inline { display:inline; margin-right: 6px; }
      select, button { padding: 6px 8px; border-radius: 8px; border: 1px solid #bfd9bf; }
      button { background: #1d4ed8; color: white; border: 0; font-weight: 700; cursor: pointer; }
      .muted { opacity: 0.8; }
    </style>
  </head>
  <body>
    <div class="container">
      <h2>Access Governance</h2>
      <p class="muted">Treasury can manage roles and capabilities. Changes take effect immediately.</p>
      <table>
        <thead>
          <tr>
            <th>User</th>
            <th>Roles</th>
            <th>Capabilities</th>
          </tr>
        </thead>
        <tbody>
          <% for (const u of users) { %>
            <tr>
              <td>
                <div><strong><%= u.name %></strong></div>
                <div class="muted"><%= u.email %></div>
              </td>
              <td>
                <% for (const r of Object.values(RoleType)) { %>
                  <form class="inline" method="post" action="/admin/access/role">
                    <input type="hidden" name="userId" value="<%= u.id %>" />
                    <input type="hidden" name="role" value="<%= r %>" />
                    <input type="hidden" name="enable" value="<%= u.roles.some(x => x.role === r) ? 'false' : 'true' %>" />
                    <button type="submit"><%= u.roles.some(x => x.role === r) ? 'Remove ' + r : 'Add ' + r %></button>
                  </form>
                <% } %>
              </td>
              <td>
                <% for (const c of Object.values(PaymentCategory)) { %>
                  <form class="inline" method="post" action="/admin/access/capability">
                    <input type="hidden" name="userId" value="<%= u.id %>" />
                    <input type="hidden" name="category" value="<%= c %>" />
                    <select name="type">
                      <option value="INITIATE" <%= u.capabilities.some(x => x.category===c && x.type==='INITIATE') ? 'selected' : '' %>>Initiate</option>
                      <option value="APPROVE" <%= u.capabilities.some(x => x.category===c && x.type==='APPROVE') ? 'selected' : '' %>>Approve</option>
                      <option value="BOTH" <%= u.capabilities.some(x => x.category===c && x.type==='BOTH') ? 'selected' : '' %>>Both</option>
                    </select>
                    <button type="submit">Save <%= c %></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </body>
</html>
