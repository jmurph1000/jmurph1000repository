<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <style>
      body { background: #e6ffe6; color: #0a2a66; font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; }
      .container { max-width: 1100px; margin: 4vh auto; }
      table { width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 6px 18px rgba(0,0,0,0.06); }
      th, td { padding: 12px 14px; border-bottom: 1px solid #eef2ee; text-align: left; }
      th { background: #dff6df; color: #0a2a66; }
      a { color: #1d4ed8; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="container">
      <h2><%= title %></h2>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Category</th>
            <th>Funding Type</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Submitted</th>
          </tr>
        </thead>
        <tbody>
          <% for (const r of list) { %>
            <tr>
              <td><a href="/requests/<%= r.id %>"><%= r.id.slice(0,8) %></a></td>
              <td><%= r.category %></td>
              <td><%= r.fundingType || '' %></td>
              <td>$<%= Number(r.amount).toLocaleString() %></td>
              <td><%= r.status %></td>
              <td><%= new Date(r.submissionDate).toLocaleString() %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </body>
</html>
